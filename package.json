    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "22.15.17",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "9.25.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-next": "16.2.1",
    "husky": "9.1.7",
    "lint-staged": "15.5.1",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "tailwindcss": "^4.1.14",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
